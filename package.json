{
  "name": "vocium",
  "version": "0.1.0",
  "description": "Desktop voice input tool — Node sidecar (single MCP server) + Tauri shell",
  "type": "module",
  "main": "dist/sidecar/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json -w",
    "test": "vitest run",
    "test:watch": "vitest",
    "sidecar": "node dist/sidecar/index.js",
    "probe:groq": "node scripts/probe-groq.mjs",
    "icons": "node scripts/gen-icons.mjs && tauri icon app-tauri/src-tauri/icons/1024x1024.png --output app-tauri/src-tauri/icons",
    "banner": "node scripts/gen-banner.mjs",
    "vad:assets": "node scripts/copy-vad-assets.mjs",
    "dev": "npm run build && npm run vad:assets && tauri dev --config app-tauri/src-tauri/tauri.conf.json",
    "build:sidecar-bin": "node scripts/build-sidecar-bin.mjs",
    "smoke:sidecar-bin": "node scripts/smoke-sidecar-bin.mjs",
    "package": "tauri build --config app-tauri/src-tauri/tauri.conf.json"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@ricky0123/vad-web": "^0.0.30",
    "onnxruntime-web": "^1.26.0",
    "opencc-js": "^1.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.1",
    "@types/node": "^22.10.5",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
