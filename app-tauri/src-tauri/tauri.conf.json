{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vocium",
  "version": "0.1.0",
  "identifier": "app.vocium.shell",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "icon",
        "title": "Vocium",
        "url": "index.html",
        "width": 240,
        "height": 112,
        "minWidth": 240,
        "minHeight": 112,
        "maxWidth": 240,
        "maxHeight": 112,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "focus": false,
        "visible": false,
        "center": false
      },
      {
        "label": "settings",
        "title": "Vocium 設定",
        "url": "settings.html",
        "width": 420,
        "height": 280,
        "minWidth": 420,
        "minHeight": 280,
        "maxWidth": 420,
        "maxHeight": 280,
        "resizable": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "focus": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; media-src 'self' mediastream:; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
