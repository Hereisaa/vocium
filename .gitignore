# --- dependencies / build output ---
node_modules/
dist/
app-tauri/src-tauri/target/
app-tauri/src-tauri/gen/
app-tauri/src-tauri/binaries/

# Bun build cache: `bun build --compile` drops `.<hash>-<seq>.bun-build`
# files next to wherever it was invoked (root + app-tauri/src-tauri/).
.*.bun-build
*.bun-build

# Local Claude Code workspace state (per-machine settings; never upstream).
.claude/

# --- local config & secrets (Groq key lives only in %APPDATA%, never here) ---
**/vocium-config.json
.env
*.local

# --- logs (may contain local paths / machine info) ---
*.log
docs/logs/

# --- internal AI workflow docs — not for the public repo ---
docs/superpowers/

# --- local-only architecture spec (kept on dev machines, not published) ---
docs/SPEC.md

# --- OS / editor noise ---
.DS_Store
Thumbs.db
.idea/
.vscode/

# NOTE: app-tauri/src-tauri/Cargo.lock is intentionally COMMITTED.
# Vocium is an application (not a library) → a pinned lockfile gives
# reproducible builds. (Previously this file ignored Cargo.lock — fixed.)

# brainstorming visual-companion artifacts (internal AI process)
.superpowers/

# vad-web + onnxruntime-web vendored browser assets (large/binary; reproducible via npm run vad:assets)
app-tauri/ui/vad/

# tauri icon side-outputs unused by this desktop-only project (regenerated by npm run icons)
app-tauri/src-tauri/icons/ios/
app-tauri/src-tauri/icons/android/
app-tauri/src-tauri/icons/Square*Logo*.png
app-tauri/src-tauri/icons/StoreLogo.png
app-tauri/src-tauri/icons/1024x1024.png
app-tauri/src-tauri/icons/icon.png
